# ==========================================
# FASTAPI CRYPTO TRADING BOT - ENVIRONMENT CONFIG
# Copy this to .env and fill in your values
# NEVER commit .env to GitHub (it's in .gitignore)
# ==========================================

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# Database
DATABASE_URL=sqlite:///./trades.db

# Binance Smart Chain (BSC) Configuration
BSC_RPC_URL=https://bsc-dataseed.binance.org/
BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545/

# Wallet Configuration (MAINNET - REAL MONEY)
# WARNING: Never share these, never commit to GitHub
PRIVATE_KEY=your_private_key_here
WALLET_ADDRESS=your_wallet_address_here

# Testnet Configuration (USE THIS FOR TESTING)
TESTNET_PRIVATE_KEY=your_testnet_private_key_here
TESTNET_WALLET_ADDRESS=your_testnet_wallet_address_here

# PancakeSwap Contracts
PANCAKE_ROUTER_ADDRESS=0x10ED43C718714eb63d5aA57B78B54704E256024E
WBNB_ADDRESS=0xBB4CdB9CBd36B01bD1cBaEBF2De08d9173bc095c

# BSCScan API (for wallet tracking)
BSCSCAN_API_KEY=your_bscscan_api_key_here

# Trading Parameters
DEFAULT_SLIPPAGE=0.05
MAX_SLIPPAGE=0.10
MIN_LIQUIDITY_USD=10000
GAS_PRICE_GWEI=5
MAX_OPEN_TRADES=3
RISK_PER_TRADE=0.02

# Copy Trading Settings
COPY_TRADING_ENABLED=false
WALLET_SCAN_INTERVAL_SECONDS=30
MIN_WALLET_WIN_RATE=0.60
MIN_WALLET_TRADES=5

# AI Scoring
AI_CONFIDENCE_THRESHOLD=0.70
LEARNING_ENABLED=true

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
